# По умолчанию — автоконвертация
* text=auto

# Исходники — всегда LF
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.tex text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Шаблоны LaTeX — LF (критично для XeLaTeX!)
storage/templates/**/*.tex text eol=lf

# Бинарные файлы — не трогать
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary